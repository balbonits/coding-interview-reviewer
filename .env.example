# ─── MongoDB (local) ──────────────────────────────────────────────────────────
# Start with: mongod --dbpath ~/data/db  (or use mongod as a service)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=coding-interview-reviewer

# ─── Ollama (local) ───────────────────────────────────────────────────────────
# AI interviewer + exercise hints/review/explain
OLLAMA_URL=http://localhost:11434
OLLAMA_INTERVIEW_MODEL=qwen2.5:14b
OLLAMA_NUM_CTX=4096

# Tip: set this in your shell profile so two models can't co-load:
# export OLLAMA_MAX_LOADED_MODELS=1
